# Django core settings (production hardening)
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# Gmail SMTP requires 2-Step Verification and an App Password (not your login password).
# Create one at: https://myaccount.google.com/apppasswords

GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant

# Google Gemini — primary AI phone comparison provider
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash-lite

# Meta Llama — chatbot provider (official Llama Stack integration)
# 1) llama model list
# 2) llama model download --source meta --model-id Llama3.1-8B-Instruct
# 3) Paste your Meta signed URL when prompted (LLAMA_DOWNLOAD_URL)
# 4) llama stack run
LLAMA_MODEL_ID=Llama3.1-8B-Instruct
LLAMA_STACK_BASE_URL=http://localhost:8321
LLAMA_DOWNLOAD_URL=your-meta-signed-download-url
LLAMA_MAX_TOKENS=1200
LLAMA_TEMPERATURE=0.2

# Claude / Anthropic — not used by the chatbot (legacy comparison tools only)
CHATBOT=your-anthropic-api-key
CLAUDE_API_KEY=your-claude-api-key
CLAUDE_MODEL=claude-3-5-haiku-20241022

# Hugging Face — used for AI phone comparison (free tier)
# Create a token at: https://huggingface.co/settings/tokens
HF_API_TOKEN=your-huggingface-token
HF_COMPARE_MODEL=Qwen/Qwen2.5-3B-Instruct

# WhatMobile scraper — polite delays and optional proxy
# WHATMOBILE_SCRAPE_LIMIT=0
# WHATMOBILE_MAX_CONCURRENT=1
# WHATMOBILE_MIN_DELAY=1.0
# WHATMOBILE_MAX_DELAY=3.0
# WHATMOBILE_MAX_RETRIES=6
# WHATMOBILE_RATE_LIMIT_BACKOFF=5.0
# USD_TO_PKR_RATE=278
# SCRAPE_PROXY_URL=
